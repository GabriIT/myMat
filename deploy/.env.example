# Required: OpenAI API key used by RAG backend and VPS vector build stage
OPENAI_API_KEY=

# VPS absolute path to Chroma vector DB built on VPS
MYMAT_DB_PATH=/home/ubuntu/mymat-deploy/vector_db

# Chroma collection name
MYMAT_COLLECTION=myrag_docs_markdown

# Comma-separated origins for CORS at API layer
MYMAT_ALLOWED_ORIGINS=http://154.12.245.254

# Optional: Ollama endpoint. Kept available but not default.
OLLAMA_URL=http://host.docker.internal:11434

# Optional: PostgreSQL + pgvector thread memory
MYMAT_THREADS_ENABLED=1
MYMAT_THREADS_DB_HOST=host.docker.internal
MYMAT_THREADS_DB_PORT=5432
MYMAT_THREADS_DB_NAME=myMAT_ops
MYMAT_THREADS_DB_USER=postgresql
MYMAT_THREADS_DB_PASSWORD=
MYMAT_THREADS_DB_SSLMODE=disable
MYMAT_THREADS_VECTOR_DIMS=3072
MYMAT_THREADS_RECENT_MESSAGES=10
MYMAT_THREADS_SEMANTIC_TOP_K=6
MYMAT_THREADS_MAX_HISTORY_MESSAGES=24

# Optional: ops DB (same DB supported)
MYMAT_OPS_ENABLED=1
MYMAT_OPS_DB_HOST=host.docker.internal
MYMAT_OPS_DB_PORT=5432
MYMAT_OPS_DB_NAME=myMAT_ops
MYMAT_OPS_DB_USER=postgresql
MYMAT_OPS_DB_PASSWORD=
MYMAT_OPS_DB_SSLMODE=disable

# UI build settings for reverse-proxy path deployment
MYMAT_BASE_PATH=/agentic-mat
VITE_BASE_PATH=/agentic-mat/
VITE_API_BASE_URL=/agentic-mat
