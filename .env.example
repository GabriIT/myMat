# LLM / embeddings
OPENAI_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434

# Vector store for Agent 1/2 RAG
MYMAT_DB_PATH=/home/gabri/apps/myMAT_app/vector_db
MYMAT_COLLECTION=myrag_docs_markdown

# API CORS
MYMAT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Thread memory (PostgreSQL + pgvector)
MYMAT_THREADS_ENABLED=1
MYMAT_THREADS_DB_HOST=127.0.0.1
MYMAT_THREADS_DB_PORT=5432
MYMAT_THREADS_DB_NAME=myMAT_ops
MYMAT_THREADS_DB_USER=postgresql
MYMAT_THREADS_DB_PASSWORD=postgresql
MYMAT_THREADS_DB_SSLMODE=disable

# Ops/business DB (can be same DB as threads)
MYMAT_OPS_ENABLED=1
MYMAT_OPS_DB_HOST=127.0.0.1
MYMAT_OPS_DB_PORT=5432
MYMAT_OPS_DB_NAME=myMAT_ops
MYMAT_OPS_DB_USER=postgresql
MYMAT_OPS_DB_PASSWORD=postgresql
MYMAT_OPS_DB_SSLMODE=disable
